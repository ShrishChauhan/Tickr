# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL — required before running migrations or any DB-backed features
# Local example: postgresql://postgres:password@localhost:5432/tickr
# Hosted example: postgresql://user:pass@db.example.com:5432/tickr
DATABASE_URL=postgresql://user:password@localhost:5432/tickr

# LLM provider (generic stub — reserved for future Anthropic swap)
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_BASE_URL=https://api.anthropic.com

# Groq — AI analysis layer (Phase 2c); get key at console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# App
ENVIRONMENT=development
LOG_LEVEL=INFO

# SEC EDGAR — required by SEC to identify the client in User-Agent headers
# Use any valid contact email address
SEC_IDENTITY=your_email@example.com

# Finnhub — real-time US equity quotes (Phase B4); get a free key at finnhub.io
# Leave blank to skip Finnhub and fall through to yfinance (delayed) quotes
FINNHUB_API_KEY=your_finnhub_api_key_here
