# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL — required before running migrations or any DB-backed features
# Local example: postgresql://postgres:password@localhost:5432/equity_research
# Hosted example: postgresql://user:pass@db.example.com:5432/equity_research
DATABASE_URL=postgresql://user:password@localhost:5432/equity_research

# LLM provider — used by the AI analysis layer (Phase 2)
LLM_API_KEY=your_api_key_here
LLM_MODEL=claude-sonnet-4-6
LLM_BASE_URL=https://api.anthropic.com

# App
ENVIRONMENT=development
LOG_LEVEL=INFO

# SEC EDGAR — required by SEC to identify the client in User-Agent headers
# Use any valid contact email address
SEC_IDENTITY=your_email@example.com
